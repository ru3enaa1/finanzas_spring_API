# ============================================================
# Template publico de configuracion
# ============================================================
# Copia este archivo a `application.properties` y rellena los
# valores con tus credenciales locales (no las subas al repo).
# ============================================================

spring.application.name=finanzas
server.port=8080
server.address=0.0.0.0

# ──────────────────────────────────────────────
# Base de datos MySQL
# ──────────────────────────────────────────────
# Cambia el nombre de BD, usuario y contrasena por los tuyos.
# Las variables ${VAR:default} permiten sobreescribir desde el
# entorno (recomendado en produccion).
spring.datasource.url=${DB_URL:jdbc:mysql://localhost:3306/finanzas_personales?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC}
spring.datasource.username=${DB_USER:root}
spring.datasource.password=${DB_PASSWORD:CHANGE_ME}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# ──────────────────────────────────────────────
# JPA / Hibernate
# ──────────────────────────────────────────────
# ddl-auto=none: las migraciones se ejecutan manualmente desde
# los scripts SQL en /database. NO usar create/update en prod.
spring.jpa.hibernate.ddl-auto=none
spring.jpa.open-in-view=false
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect

# ──────────────────────────────────────────────
# Thymeleaf
# ──────────────────────────────────────────────
spring.thymeleaf.prefix=classpath:/templates/
spring.thymeleaf.suffix=.html
spring.thymeleaf.cache=false

# ──────────────────────────────────────────────
# Spring MVC
# ──────────────────────────────────────────────
spring.mvc.hiddenmethod.filter.enabled=true
